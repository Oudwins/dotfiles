{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  // plugins
  // not sure what this one is
  // https://github.com/obra/superpowers/blob/main/docs/README.opencode.md
  // https://github.com/spoons-and-mirrors/subtask2
  // https://github.com/different-ai/opencode-scheduler
  "plugin": [
    // smart context management
    // https://github.com/Opencode-DCP/opencode-dynamic-context-pruning
    "@tarquinen/opencode-dcp@latest",
    // Adds native web search
    "opencode-websearch-cited@1.2.0",
  ],
  "mcp": {
    // https://help.figma.com/hc/en-us/articles/32132100833559-Guide-to-the-Figma-MCP-server
    "figma": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "timeout": 60000,
      "oauth": {
        "clientId": "YrhrOrJCDyNE8SOw7x3jwr",
        "clientSecret": "NrSeGMWQLKBtiGiqqwf862ZsiMr44O",
      },
    },
    "nextdevtools": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
    },
    // Linear mcp for tickets
    // context7 for up to date docs
    // sentry mcp for debugging production
  },
  "lsp": {},
  "provider": {
    "openai": {
      "options": {
        // required for web search plugin
        "websearch_cited": {
          "model": "gpt-5.4",
        },
      },
      "models": {
        "gpt-5.4": {},
      },
    },
    "vertex_anthropic": {
      "npm": "@ai-sdk/google-vertex/anthropic",
      "name": "Google Vertex Anthropic",
      "options": {
        "project": "{env:GOOGLE_CLOUD_PROJECT}",
        "location": "{env:VERTEX_LOCATION}",
      },
      "models": {
        "claude-opus-4-5": {
          "id": "claude-opus-4-5@20251101",
        },
      },
    },
  },
  "agent": {},
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "doom_loop": "ask",
    "external_directory": "allow",
  },
}
